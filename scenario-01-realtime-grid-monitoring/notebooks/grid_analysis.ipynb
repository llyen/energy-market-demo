# MARKDOWN: ## 3. Detekcja anomalii — metoda Z-score

# CODE: Z-score anomaly detection
def detect_anomalies_zscore(df, column, threshold=3.0):
    """Detect anomalies using Z-score method.
    Returns a boolean mask where True indicates an anomaly.
    """
    mean = df[column].mean()
    std = df[column].std()
    z_scores = np.abs((df[column] - mean) / std)
    return z_scores > threshold


# Apply Z-score detection to key parameters
anomaly_columns = ["voltage_kv", "frequency_hz", "load_pct", "transformer_temp_c"]
z_threshold = 3.0

print(f"Detekcja anomalii Z-score (próg: {z_threshold}):\n")
anomaly_results = {}
for col in anomaly_columns:
    mask = detect_anomalies_zscore(df_readings, col, z_threshold)
    n_anomalies = mask.sum()
    pct = n_anomalies / len(df_readings) * 100
    anomaly_results[col] = {
        "count": n_anomalies,
        "pct": pct,
        "mask": mask,
    }
    print(f"  {col:25s}: {n_anomalies:>6,} anomalii ({pct:.2f}%)")

# CODE: Per-substation Z-score analysis
