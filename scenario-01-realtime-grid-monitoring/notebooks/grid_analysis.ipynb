# MARKDOWN: ## 9. Indeks stabilności sieci

# CODE: Grid stability index calculation
def calculate_stability_index(df):
    """Calculate a composite grid stability index (0-100).
    Higher = more stable.
    """
    voltage_std = df["voltage_kv"].std()
    voltage_score = max(0, 100 - (voltage_std / 2.2) * 10)

    freq_max_dev = (df["frequency_hz"] - 50.0).abs().max()
    freq_score = max(0, 100 - freq_max_dev * 200)

    avg_load = df["load_pct"].mean()
    overloaded = (df["load_pct"] > 90).sum() / len(df) * 100
    load_score = max(0, 100 - (avg_load - 50) * 1.5 - overloaded * 5)

    avg_temp = df["transformer_temp_c"].mean()
    critical_temp = (df["transformer_temp_c"] > 85).sum() / len(df) * 100
    temp_score = max(0, 100 - (avg_temp - 50) * 1.0 - critical_temp * 10)

    overall = (voltage_score + freq_score + load_score + temp_score) / 4.0

    return {
        "voltage_stability": round(voltage_score, 1),
        "frequency_stability": round(freq_score, 1),
        "load_stability": round(load_score, 1),
        "temperature_stability": round(temp_score, 1),
        "overall_index": round(overall, 1),
    }


# Overall index
overall_idx = calculate_stability_index(df_readings)
print("Indeks stabilności sieci (cała sieć):")
for k, v in overall_idx.items():
    label = k.replace("_", " ").title()
    bar = "█" * int(v / 5) + "░" * (20 - int(v / 5))
    print(f"  {label:30s}: {v:6.1f}/100  {bar}")

# Per-station index
print("\nIndeks stabilności wg stacji (top 5 najgorsze):")
station_indices = []
for name, grp in df_readings.groupby("substation_name"):
    idx = calculate_stability_index(grp)
    idx["station"] = name
    station_indices.append(idx)

station_idx_df = pd.DataFrame(station_indices).sort_values("overall_index")
print(station_idx_df[["station", "overall_index", "voltage_stability",
                       "frequency_stability", "load_stability"]].head(5).to_string(index=False))


